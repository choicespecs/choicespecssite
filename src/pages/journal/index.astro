---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.vue';
import Footer from '../../components/Footer.astro';

const MONTH_NAMES = [
    'January','February','March','April','May','June',
    'July','August','September','October','November','December'
];
const ENTRIES_PER_PAGE = 8;

const posts = await Astro.glob('./**/*.md');
const sorted = posts.sort((a, b) => new Date(b.frontmatter.date) - new Date(a.frontmatter.date));

const grouped = {};
for (var gi = 0; gi < sorted.length; gi++) {
    var gpost = sorted[gi];
    var gd = new Date(gpost.frontmatter.date);
    var gyear = gd.getFullYear();
    var gmonth = gd.getMonth();
    if (!grouped[gyear]) grouped[gyear] = {};
    if (!grouped[gyear][gmonth]) grouped[gyear][gmonth] = [];
    grouped[gyear][gmonth].push({ post: gpost, idx: gi });
}

const years = Object.keys(grouped).map(Number).sort((a, b) => b - a);
---

<style>
    .page-wrapper {
        margin-top: 70px;
        min-height: calc(100vh - 70px);
        max-width: 1100px;
        margin-left: auto;
        margin-right: auto;
        padding: 2em 1.25em 4em;
    }

    .page-header {
        margin-bottom: 1.75em;
    }

    .page-title {
        font-size: 2rem;
        margin-bottom: 0.3em;
    }

    .section-divider {
        border: none;
        border-top: 2px solid var(--button-color);
    }

    /* ── Mobile archive widget ─────────────────────────────── */
    .archive-mobile {
        display: block;
        border: 1px solid #333;
        border-radius: 8px;
        overflow: hidden;
        margin-bottom: 2em;
    }

    .archive-mobile summary {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.85em 1.1em;
        background: #1c1c1c;
        cursor: pointer;
        user-select: none;
        list-style: none;
    }

    .archive-mobile summary::-webkit-details-marker { display: none; }

    .archive-mobile-label {
        display: flex;
        align-items: center;
        gap: 0.5em;
        font-size: 0.82rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #bbb;
    }

    .archive-mobile-label svg {
        width: 14px;
        height: 14px;
        fill: var(--button-color);
        flex-shrink: 0;
    }

    .archive-mobile-chevron {
        font-size: 0.75rem;
        color: var(--button-color);
        transition: transform 200ms ease;
    }

    .archive-mobile[open] .archive-mobile-chevron {
        transform: rotate(180deg);
    }

    .archive-mobile-body {
        background: #161616;
        padding: 1.25em 1.1em 1.1em;
        display: flex;
        flex-direction: column;
        gap: 1.1em;
    }

    .archive-mobile-year-row {
        display: flex;
        flex-direction: column;
        gap: 0.5em;
    }

    .archive-mobile-year-label {
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--button-color);
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .archive-mobile-months {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4em;
    }

    .archive-chip {
        display: inline-block;
        padding: 0.3em 0.75em;
        border-radius: 20px;
        background: #252525;
        border: 1px solid #333;
        font-size: 0.8rem;
        color: #bbb;
        text-decoration: none;
        cursor: pointer;
        transition: background 150ms, color 150ms, border-color 150ms;
    }

    .archive-chip:hover {
        background: #2e2e2e;
        color: var(--button-color);
        border-color: var(--button-color);
    }

    /* ── Layout ───────────────────────────────────────────── */
    .content-row {
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    /* Desktop sidebar — hidden on mobile */
    .sidebar {
        display: none;
    }

    .posts-area {
        flex: 1;
        min-width: 0;
    }

    /* ── Year / month groups ──────────────────────────────── */
    .year-group {
        margin-bottom: 2.75em;
    }

    .year-heading {
        font-size: 1.5rem;
        color: var(--button-color);
        margin-bottom: 1.1em;
        scroll-margin-top: 90px;
    }

    .month-group {
        margin-bottom: 1.75em;
        padding-left: 1em;
        border-left: 2px solid #2e2e2e;
        scroll-margin-top: 90px;
    }

    .month-heading {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #777;
        margin-bottom: 0.85em;
    }

    .post-list {
        display: flex;
        flex-direction: column;
        gap: 1.1em;
    }

    .post-card h2 {
        font-size: 1.05rem;
        margin-bottom: 0.15em;
    }

    .post-card h2 a {
        color: inherit;
        text-decoration: none;
    }

    .post-card h2 a:hover {
        color: var(--button-color);
    }

    .post-meta {
        color: #777;
        font-size: 0.8rem;
        margin-bottom: 0.25em;
    }

    .post-description {
        line-height: 1.6;
        color: #bbb;
        font-size: 0.9rem;
    }

    /* ── Pagination ───────────────────────────────────────── */
    .pagination {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.4em;
        margin-top: 2.5em;
        flex-wrap: wrap;
    }

    .pagination button {
        min-width: 36px;
        height: 36px;
        padding: 0 0.5em;
        background: #1c1c1c;
        border: 1px solid #333;
        border-radius: 6px;
        color: #ccc;
        font-size: 0.85rem;
        cursor: pointer;
        transition: background 150ms, color 150ms, border-color 150ms;
    }

    .pagination button:hover:not(:disabled) {
        background: #2a2a2a;
        border-color: #555;
        color: #fff;
    }

    .pagination button.active {
        background: var(--button-color);
        border-color: var(--button-color);
        color: #111;
        font-weight: 700;
    }

    .pagination button:disabled {
        opacity: 0.3;
        cursor: default;
    }

    .empty {
        color: #777;
    }

    /* ── Desktop layout ───────────────────────────────────── */
    @media screen and (min-width: 641px) {
        .page-wrapper {
            padding: 2.5em 2em 4em;
        }

        .page-title {
            font-size: 2.5rem;
        }
    }

    @media screen and (min-width: 941px) {
        .archive-mobile {
            display: none;
        }

        .content-row {
            flex-direction: row;
            align-items: flex-start;
            gap: 3em;
        }

        /* ── Desktop sidebar ────────────────────────────── */
        .sidebar {
            display: flex;
            flex-direction: column;
            width: 210px;
            flex-shrink: 0;
            position: sticky;
            top: 90px;
            background: #161616;
            border: 1px solid #2a2a2a;
            border-radius: 8px;
            overflow: hidden;
        }

        .sidebar-header {
            padding: 0.85em 1em;
            background: #1c1c1c;
            border-bottom: 1px solid #2a2a2a;
            display: flex;
            align-items: center;
            gap: 0.5em;
        }

        .sidebar-header svg {
            width: 13px;
            height: 13px;
            fill: var(--button-color);
            flex-shrink: 0;
        }

        .sidebar-title {
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: #999;
            margin: 0;
        }

        .sidebar-body {
            padding: 0.75em 0;
            overflow-y: auto;
            max-height: calc(100vh - 200px);
        }

        .sidebar-year-section {
            margin-bottom: 0.15em;
        }

        .sidebar-year-btn {
            width: 100%;
            background: none;
            border: none;
            padding: 0.45em 1em;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.5em;
            text-align: left;
        }

        .sidebar-year-btn:hover {
            background: #1e1e1e;
        }

        .sidebar-year-label {
            font-size: 0.9rem;
            font-weight: 700;
            color: var(--button-color);
        }

        .sidebar-year-count {
            font-size: 0.7rem;
            color: #555;
        }

        .sidebar-chevron {
            font-size: 0.6rem;
            color: #555;
            transition: transform 200ms ease;
            flex-shrink: 0;
        }

        .sidebar-year-btn.collapsed .sidebar-chevron {
            transform: rotate(-90deg);
        }

        .sidebar-months {
            overflow: hidden;
            transition: max-height 250ms ease;
        }

        .sidebar-months.collapsed {
            max-height: 0 !important;
        }

        .sidebar-month-link {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.35em 1em 0.35em 1.6em;
            font-size: 0.82rem;
            color: #888;
            text-decoration: none;
            transition: color 150ms, background 150ms;
        }

        .sidebar-month-link:hover {
            color: var(--button-color);
            background: #1a1a1a;
        }

        .sidebar-month-count {
            font-size: 0.7rem;
            color: #444;
        }
    }
</style>

<script>
    var ENTRIES_PER_PAGE = 8;
    var currentPage = 0;

    function showPage(page) {
        var paginationEl = document.querySelector('.pagination');
        var total = paginationEl ? parseInt(paginationEl.getAttribute('data-total')) : 0;
        var totalPages = Math.ceil(total / ENTRIES_PER_PAGE);
        if (page < 0 || page >= totalPages) return;
        currentPage = page;

        var start = page * ENTRIES_PER_PAGE;
        var end = start + ENTRIES_PER_PAGE;

        // Show/hide entries
        var entries = document.querySelectorAll('[data-entry-index]');
        for (var i = 0; i < entries.length; i++) {
            var idx = parseInt(entries[i].getAttribute('data-entry-index'));
            entries[i].style.display = (idx >= start && idx < end) ? '' : 'none';
        }

        // Show/hide month groups based on whether they have visible entries
        var monthGroups = document.querySelectorAll('[data-month-group]');
        for (var j = 0; j < monthGroups.length; j++) {
            var mg = monthGroups[j];
            var mgEntries = mg.querySelectorAll('[data-entry-index]');
            var mgVisible = false;
            for (var jj = 0; jj < mgEntries.length; jj++) {
                if (mgEntries[jj].style.display !== 'none') { mgVisible = true; break; }
            }
            mg.style.display = mgVisible ? '' : 'none';
        }

        // Show/hide year groups
        var yearGroups = document.querySelectorAll('[data-year-group]');
        for (var k = 0; k < yearGroups.length; k++) {
            var yg = yearGroups[k];
            var ygEntries = yg.querySelectorAll('[data-entry-index]');
            var ygVisible = false;
            for (var kk = 0; kk < ygEntries.length; kk++) {
                if (ygEntries[kk].style.display !== 'none') { ygVisible = true; break; }
            }
            yg.style.display = ygVisible ? '' : 'none';
        }

        renderPagination(total);
    }

    function renderPagination(total) {
        var container = document.querySelector('.pagination');
        if (!container) return;
        var totalPages = Math.ceil(total / ENTRIES_PER_PAGE);
        container.innerHTML = '';
        if (totalPages <= 1) return;

        var prev = document.createElement('button');
        prev.innerHTML = '&larr;';
        prev.setAttribute('aria-label', 'Previous page');
        prev.disabled = currentPage === 0;
        prev.addEventListener('click', function() { jumpToPage(currentPage - 1); });
        container.appendChild(prev);

        for (var p = 0; p < totalPages; p++) {
            (function(pageNum) {
                var btn = document.createElement('button');
                btn.textContent = pageNum + 1;
                if (pageNum === currentPage) btn.classList.add('active');
                btn.addEventListener('click', function() { jumpToPage(pageNum); });
                container.appendChild(btn);
            })(p);
        }

        var next = document.createElement('button');
        next.innerHTML = '&rarr;';
        next.setAttribute('aria-label', 'Next page');
        next.disabled = currentPage === totalPages - 1;
        next.addEventListener('click', function() { jumpToPage(currentPage + 1); });
        container.appendChild(next);
    }

    function jumpToPage(page) {
        showPage(page);
        var postsArea = document.querySelector('.posts-area');
        if (postsArea) {
            window.scrollTo({ top: postsArea.getBoundingClientRect().top + window.scrollY - 90, behavior: 'smooth' });
        }
    }

    function jumpToMonth(firstEntryIdx, anchorId) {
        var targetPage = Math.floor(firstEntryIdx / ENTRIES_PER_PAGE);
        showPage(targetPage);
        setTimeout(function() {
            var el = document.getElementById(anchorId);
            if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 80);
    }

    document.addEventListener('DOMContentLoaded', function() {
        showPage(0);

        // Sidebar year collapse toggles
        var yearBtns = document.querySelectorAll('.sidebar-year-btn');
        for (var i = 0; i < yearBtns.length; i++) {
            (function(btn) {
                btn.addEventListener('click', function() {
                    var targetId = btn.getAttribute('data-target');
                    var monthsEl = document.getElementById(targetId);
                    if (!monthsEl) return;
                    var isCollapsed = monthsEl.classList.contains('collapsed');
                    if (isCollapsed) {
                        monthsEl.style.maxHeight = monthsEl.scrollHeight + 'px';
                        monthsEl.classList.remove('collapsed');
                        btn.classList.remove('collapsed');
                    } else {
                        monthsEl.style.maxHeight = monthsEl.scrollHeight + 'px';
                        requestAnimationFrame(function() {
                            monthsEl.style.maxHeight = '0';
                            monthsEl.classList.add('collapsed');
                            btn.classList.add('collapsed');
                        });
                    }
                });
            })(yearBtns[i]);
        }

        // Sidebar + mobile month links
        var monthLinks = document.querySelectorAll('[data-first-entry]');
        for (var j = 0; j < monthLinks.length; j++) {
            (function(link) {
                link.addEventListener('click', function(e) {
                    e.preventDefault();
                    var firstEntry = parseInt(link.getAttribute('data-first-entry'));
                    var anchorId = link.getAttribute('data-anchor');
                    // Close mobile archive if open
                    var mobileArchive = document.querySelector('.archive-mobile');
                    if (mobileArchive) mobileArchive.removeAttribute('open');
                    jumpToMonth(firstEntry, anchorId);
                });
            })(monthLinks[j]);
        }
    });
</script>

<BaseLayout>
    <Navbar client:load />
    <div class="page-wrapper">
        <div class="page-header">
            <h1 class="page-title">Journal</h1>
            <hr class="section-divider" />
        </div>

        {years.length === 0 ? (
            <p class="empty">No entries yet.</p>
        ) : (
            <div>
                <!-- Mobile archive widget -->
                <details class="archive-mobile">
                    <summary>
                        <span class="archive-mobile-label">
                            <svg viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg"><path d="M1 2.5A1.5 1.5 0 0 1 2.5 1h11A1.5 1.5 0 0 1 15 2.5v2A1.5 1.5 0 0 1 13.5 6H2.5A1.5 1.5 0 0 1 1 4.5v-2zm1 8A1.5 1.5 0 0 1 3.5 9h9a1.5 1.5 0 0 1 1.5 1.5v2a1.5 1.5 0 0 1-1.5 1.5h-9A1.5 1.5 0 0 1 2 12.5v-2z"/></svg>
                            Archive
                        </span>
                        <span class="archive-mobile-chevron">&#9660;</span>
                    </summary>
                    <div class="archive-mobile-body">
                        {years.map(year => (
                            <div class="archive-mobile-year-row">
                                <span class="archive-mobile-year-label">{year}</span>
                                <div class="archive-mobile-months">
                                    {Object.keys(grouped[year]).map(Number).sort((a, b) => b - a).map(month => (
                                        <a
                                            class="archive-chip"
                                            href={`#anchor-${year}-${month}`}
                                            data-first-entry={grouped[year][month][0].idx}
                                            data-anchor={`anchor-${year}-${month}`}
                                        >
                                            {MONTH_NAMES[month]}
                                            <span style="opacity:0.45;margin-left:0.3em;font-size:0.75em">
                                                {grouped[year][month].length}
                                            </span>
                                        </a>
                                    ))}
                                </div>
                            </div>
                        ))}
                    </div>
                </details>

                <div class="content-row">
                    <!-- Desktop sidebar -->
                    <aside class="sidebar">
                        <div class="sidebar-header">
                            <svg viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg"><path d="M1 2.5A1.5 1.5 0 0 1 2.5 1h11A1.5 1.5 0 0 1 15 2.5v2A1.5 1.5 0 0 1 13.5 6H2.5A1.5 1.5 0 0 1 1 4.5v-2zm1 8A1.5 1.5 0 0 1 3.5 9h9a1.5 1.5 0 0 1 1.5 1.5v2a1.5 1.5 0 0 1-1.5 1.5h-9A1.5 1.5 0 0 1 2 12.5v-2z"/></svg>
                            <p class="sidebar-title">Archive</p>
                        </div>
                        <div class="sidebar-body">
                            {years.map((year, yi) => {
                                var monthKeys = Object.keys(grouped[year]).map(Number).sort((a, b) => b - a);
                                var yearTotal = monthKeys.reduce(function(acc, m) { return acc + grouped[year][m].length; }, 0);
                                return (
                                    <div class="sidebar-year-section">
                                        <button
                                            class="sidebar-year-btn"
                                            data-target={`sidebar-months-${year}`}
                                        >
                                            <span class="sidebar-year-label">{year}</span>
                                            <span class="sidebar-year-count">{yearTotal}</span>
                                            <span class="sidebar-chevron">&#9660;</span>
                                        </button>
                                        <div
                                            class="sidebar-months"
                                            id={`sidebar-months-${year}`}
                                            style="max-height: 500px"
                                        >
                                            {monthKeys.map(month => (
                                                <a
                                                    class="sidebar-month-link"
                                                    href={`#anchor-${year}-${month}`}
                                                    data-first-entry={grouped[year][month][0].idx}
                                                    data-anchor={`anchor-${year}-${month}`}
                                                >
                                                    {MONTH_NAMES[month]}
                                                    <span class="sidebar-month-count">{grouped[year][month].length}</span>
                                                </a>
                                            ))}
                                        </div>
                                    </div>
                                );
                            })}
                        </div>
                    </aside>

                    <!-- Posts + pagination -->
                    <div class="posts-area">
                        {years.map(year => (
                            <div class="year-group" data-year-group={year}>
                                <h2 class="year-heading" id={`anchor-${year}`}>{year}</h2>
                                {Object.keys(grouped[year]).map(Number).sort((a, b) => b - a).map(month => (
                                    <div class="month-group" id={`anchor-${year}-${month}`} data-month-group={`${year}-${month}`}>
                                        <h3 class="month-heading">{MONTH_NAMES[month]}</h3>
                                        <div class="post-list">
                                            {grouped[year][month].map(item => (
                                                <article class="post-card" data-entry-index={item.idx}>
                                                    <h2><a href={item.post.url}>{item.post.frontmatter.title}</a></h2>
                                                    <p class="post-meta">{new Date(item.post.frontmatter.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
                                                    {item.post.frontmatter.description && (
                                                        <p class="post-description">{item.post.frontmatter.description}</p>
                                                    )}
                                                </article>
                                            ))}
                                        </div>
                                    </div>
                                ))}
                            </div>
                        ))}

                        <div class="pagination" data-total={sorted.length}></div>
                    </div>
                </div>
            </div>
        )}
    </div>
    <Footer />
</BaseLayout>
