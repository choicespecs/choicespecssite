---
import projects from '../data/projects.json';

const githubLink = 'https://github.com/choicespecs';
const githubLogo = 'https://choicespecs-website.s3.us-east-2.amazonaws.com/github.png';
---

<style>
    /* ── Section wrapper ── */
    #projects {
        margin: 1.5em auto;
        width: 95%;
        max-width: 1400px;
        border-radius: 12px;
        border: 1px solid black;
        -webkit-box-shadow: -8px 4px 15px 0px rgba(0, 0, 0, 0.35);
        box-shadow: -8px 4px 15px 0px rgba(0, 0, 0, 0.35);
        padding-bottom: 1.5em;
        scroll-margin-top: 100px;
    }

    /* ── Header bar ── */
    .projects-title {
        padding: 0.8em 1em;
        position: relative;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .projects-title::after {
        content: '';
        width: calc(100% - 2em);
        border-bottom: 1px solid black;
        position: absolute;
        bottom: 0;
        left: 1em;
    }

    .projects-title h1 {
        font-size: 1.4em;
    }

    .github-link img {
        width: 28px;
        height: 28px;
        display: block;
    }

    /* ── Card grid ── */
    .projects-grid {
        padding: 1em;
        display: grid;
        grid-template-columns: 1fr;
        gap: 1em;
    }

    /* ── Individual card ── */
    .project-card {
        display: flex;
        flex-direction: column;
        border: 1px solid rgba(0, 0, 0, 0.2);
        border-radius: 10px;
        overflow: hidden;
        background-color: white;
        -webkit-box-shadow: 2px 2px 10px 0px rgba(0, 0, 0, 0.08);
        box-shadow: 2px 2px 10px 0px rgba(0, 0, 0, 0.08);
    }

    .project-card[data-hidden] {
        display: none !important;
    }

    .card-header {
        padding: 0.6em 1em;
        background-color: rgba(109, 109, 109, 0.12);
        display: flex;
        align-items: center;
    }

    .card-language {
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    .card-body {
        padding: 1em;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.6em;
    }

    .card-name {
        font-size: 1em;
        font-weight: 700;
        text-decoration: underline;
        word-break: break-word;
    }

    .card-desc {
        font-size: 0.9em;
        line-height: 1.6;
        font-weight: 300;
        flex: 1;
    }

    .card-topics {
        display: flex;
        flex-wrap: wrap;
        gap: 5px;
        margin-top: 0.3em;
    }

    .topic-tag {
        font-size: 11px;
        padding: 3px 8px;
        background-color: rgba(109, 109, 109, 0.12);
        border-radius: 999px;
        letter-spacing: 0.3px;
    }

    .card-footer {
        padding: 0.8em 1em;
        display: flex;
        gap: 0.6em;
        flex-wrap: wrap;
        border-top: 1px solid rgba(0, 0, 0, 0.08);
    }

    .card-footer a {
        font-size: 11px;
        letter-spacing: 1.5px;
        padding: 7px 14px;
        border: 1px solid black;
        border-radius: 4px;
        text-transform: uppercase;
        transition: background-color 0.2s, color 0.2s;
    }

    .card-footer a:hover {
        background-color: black;
        color: white;
    }

    .link-live {
        background-color: var(--button-color);
        border-color: var(--button-color) !important;
    }

    .link-live:hover {
        background-color: #d9a52e !important;
        color: black !important;
    }

    /* ── Carousel navigation ── */
    .carousel-nav {
        display: none;
        justify-content: center;
        align-items: center;
        gap: 1em;
        padding: 0.5em 1em 0;
    }

    .carousel-nav.visible {
        display: flex;
    }

    .carousel-btn {
        background: var(--button-color);
        border: 1px solid rgba(0, 0, 0, 0.15);
        border-radius: 50%;
        width: 36px;
        height: 36px;
        font-size: 20px;
        line-height: 1;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: opacity 0.2s, transform 0.2s;
        flex-shrink: 0;
    }

    .carousel-btn:disabled {
        opacity: 0.25;
        cursor: not-allowed;
        transform: none !important;
    }

    .carousel-btn:not(:disabled):hover {
        transform: scale(1.1);
    }

    .carousel-dots {
        display: flex;
        gap: 8px;
        align-items: center;
    }

    .dot {
        width: 9px;
        height: 9px;
        border-radius: 50%;
        border: none;
        background: rgba(0, 0, 0, 0.2);
        cursor: pointer;
        padding: 0;
        transition: background 0.2s, transform 0.2s;
    }

    .dot.active {
        background: var(--button-color);
        transform: scale(1.3);
    }

    /* ── Tablet / iPad: 2×2 grid (4 per page) ── */
    @media screen and (min-width: 641px) {
        #projects {
            width: 92%;
            margin: 2em auto;
        }

        .projects-title {
            padding: 1em 1.5em;
        }

        .projects-title h1 {
            font-size: 1.6em;
        }

        .projects-title::after {
            width: calc(100% - 3em);
            left: 1.5em;
        }

        .projects-grid {
            padding: 1.2em 1.5em;
            grid-template-columns: repeat(2, 1fr);
            gap: 1.2em;
        }

        .card-name {
            font-size: 1.05em;
        }

        .card-desc {
            font-size: 0.9em;
        }
    }

    /* ── Desktop ── */
    @media screen and (min-width: 941px) {
        #projects {
            width: 90%;
            margin: 2em auto;
        }

        .projects-title {
            padding: 1em 2em;
        }

        .projects-title h1 {
            font-size: 1.8em;
        }

        .projects-title::after {
            width: calc(100% - 4em);
            left: 2em;
        }

        .github-link img {
            width: 32px;
            height: 32px;
        }

        .projects-grid {
            padding: 1.5em 2em;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5em;
        }

        .project-card {
            transition: transform 0.3s, box-shadow 0.3s;
        }

        .project-card:not([data-hidden]):hover {
            transform: scale(1.03);
            -webkit-box-shadow: 5px -5px 30px 8px rgba(0, 0, 0, 0.14);
            box-shadow: 5px -5px 30px 8px rgba(0, 0, 0, 0.14);
        }

        .card-name {
            font-size: 1.1em;
        }

        .card-desc {
            font-size: 0.95em;
        }

        .card-footer a {
            font-size: 12px;
        }

        .carousel-nav {
            padding: 0.5em 2em 0;
        }
    }

    /* ── Wide desktop ── */
    @media screen and (min-width: 1200px) {
        .projects-grid {
            padding: 2em 2.5em;
            gap: 2em;
        }

        .card-body {
            padding: 1.2em;
        }
    }
</style>

<section id="projects">
    <header class="projects-title">
        <h1>Projects</h1>
        <a class="github-link" href={githubLink} aria-label="GitHub profile">
            <img src={githubLogo} alt="GitHub">
        </a>
    </header>

    <div class="projects-grid" id="projects-grid">
        {projects.map((obj, i) => (
            <article class="project-card" data-index={String(i)} {...(i >= 3 ? { 'data-hidden': '' } : {})}>
                <header class="card-header">
                    <span class="card-language">{obj.language}</span>
                </header>
                <div class="card-body">
                    <h2 class="card-name">{obj.name}</h2>
                    <p class="card-desc">{obj.description}</p>
                    <div class="card-topics">
                        {obj.topics.map(t => (
                            <span class="topic-tag">{t}</span>
                        ))}
                    </div>
                </div>
                <footer class="card-footer">
                    {obj.live_url && (
                        <a href={obj.live_url} target="_blank" rel="noopener" class="link-live">Live Demo</a>
                    )}
                    <a href={obj.html_url} target="_blank" rel="noopener">GitHub</a>
                </footer>
            </article>
        ))}
    </div>

    <div class="carousel-nav" id="carousel-nav">
        <button class="carousel-btn" id="prev-btn" aria-label="Previous page">&#8249;</button>
        <div class="carousel-dots" id="carousel-dots"></div>
        <button class="carousel-btn" id="next-btn" aria-label="Next page">&#8250;</button>
    </div>
</section>

<script>
    function initCarousel() {
        const grid = document.getElementById('projects-grid');
        if (!grid) return;

        const cards = Array.from(grid.querySelectorAll('.project-card'));
        const nav = document.getElementById('carousel-nav');
        const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
        const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
        const dotsContainer = document.getElementById('carousel-dots');

        if (!nav || !prevBtn || !nextBtn || !dotsContainer) return;

        let currentPage = 0;

        function itemsPerPage(): number {
            if (window.innerWidth < 641) return 1;   // mobile:  1 per page
            if (window.innerWidth < 941) return 4;   // tablet:  2×2 grid
            return 3;                                  // desktop: 3-column grid
        }

        function totalPages(): number {
            return Math.ceil(cards.length / itemsPerPage());
        }

        function render() {
            const ipp = itemsPerPage();
            const pages = totalPages();
            const start = currentPage * ipp;
            const end = start + ipp;

            cards.forEach((card, i) => {
                if (i >= start && i < end) {
                    card.removeAttribute('data-hidden');
                } else {
                    card.setAttribute('data-hidden', '');
                }
            });

            prevBtn.disabled = currentPage === 0;
            nextBtn.disabled = currentPage >= pages - 1;

            // Rebuild dots
            dotsContainer.innerHTML = '';
            for (let i = 0; i < pages; i++) {
                const dot = document.createElement('button');
                dot.className = 'dot' + (i === currentPage ? ' active' : '');
                dot.setAttribute('aria-label', `Page ${i + 1}`);
                dot.addEventListener('click', () => { currentPage = i; render(); });
                dotsContainer.appendChild(dot);
            }

            // Only show nav when multiple pages exist
            if (pages > 1) {
                nav.classList.add('visible');
            } else {
                nav.classList.remove('visible');
            }
        }

        prevBtn.addEventListener('click', () => {
            if (currentPage > 0) { currentPage--; render(); }
        });

        nextBtn.addEventListener('click', () => {
            if (currentPage < totalPages() - 1) { currentPage++; render(); }
        });

        // Reset to page 0 whenever crossing a breakpoint
        let lastIpp = itemsPerPage();
        window.addEventListener('resize', () => {
            const newIpp = itemsPerPage();
            if (newIpp !== lastIpp) {
                lastIpp = newIpp;
                currentPage = 0;
                render();
            }
        });

        render();
    }

    document.addEventListener('DOMContentLoaded', initCarousel);
</script>
