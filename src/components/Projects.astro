---
import projects from '../data/projects.json';

const githubLink = 'https://github.com/choicespecs';
const githubLogo = 'https://choicespecs-website.s3.us-east-2.amazonaws.com/github.png';

const languages = ['All', ...Array.from(new Set(projects.map(p => p.language))).sort()];
---

<style>
    /* ── Section wrapper ── */
    #projects {
        margin: 1.5em auto;
        width: 95%;
        max-width: 1400px;
        border-radius: 12px;
        border: 1px solid black;
        -webkit-box-shadow: -8px 4px 15px 0px rgba(0, 0, 0, 0.35);
        box-shadow: -8px 4px 15px 0px rgba(0, 0, 0, 0.35);
        padding-bottom: 1.5em;
        scroll-margin-top: 100px;
    }

    /* ── Header bar ── */
    .projects-title {
        padding: 0.8em 1em;
        position: relative;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .projects-title::after {
        content: '';
        width: calc(100% - 2em);
        border-bottom: 1px solid black;
        position: absolute;
        bottom: 0;
        left: 1em;
    }

    .projects-title h1 {
        font-size: 1.4em;
    }

    .github-link img {
        width: 28px;
        height: 28px;
        display: block;
    }

    /* ── Filter bar ── */
    .filter-bar {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5em;
        padding: 0.8em 1em 0;
    }

    .filter-btn {
        font-size: 11px;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        padding: 6px 14px;
        border: 1px solid black;
        border-radius: 4px;
        background: white;
        cursor: pointer;
        transition: background-color 0.2s, color 0.2s;
    }

    .filter-btn:hover {
        background-color: rgba(0, 0, 0, 0.06);
    }

    .filter-btn.active {
        background-color: var(--button-color);
        border-color: var(--button-color);
    }

    /* ── Card grid ── */
    .projects-grid {
        padding: 1em;
        display: grid;
        grid-template-columns: 1fr;
        gap: 1em;
    }

    /* ── Individual card ── */
    .project-card {
        display: flex;
        flex-direction: column;
        border: 1px solid rgba(0, 0, 0, 0.2);
        border-radius: 10px;
        overflow: hidden;
        background-color: white;
        -webkit-box-shadow: 2px 2px 10px 0px rgba(0, 0, 0, 0.08);
        box-shadow: 2px 2px 10px 0px rgba(0, 0, 0, 0.08);
    }

    .project-card[data-hidden] {
        display: none !important;
    }

    .card-header {
        padding: 0.6em 1em;
        background-color: rgba(109, 109, 109, 0.12);
        display: flex;
        align-items: center;
    }

    .card-language {
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    .card-body {
        padding: 1em;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.6em;
    }

    .card-name {
        font-size: 1em;
        font-weight: 700;
        text-decoration: underline;
        word-break: break-word;
    }

    .card-desc {
        font-size: 0.9em;
        line-height: 1.6;
        font-weight: 300;
        flex: 1;
    }

    .card-topics {
        display: flex;
        flex-wrap: wrap;
        gap: 5px;
        margin-top: 0.3em;
    }

    .topic-tag {
        font-size: 11px;
        padding: 3px 8px;
        background-color: rgba(109, 109, 109, 0.12);
        border-radius: 999px;
        letter-spacing: 0.3px;
    }

    .card-footer {
        padding: 0.8em 1em;
        display: flex;
        gap: 0.6em;
        flex-wrap: wrap;
        border-top: 1px solid rgba(0, 0, 0, 0.08);
    }

    .card-footer a {
        font-size: 11px;
        letter-spacing: 1.5px;
        padding: 7px 14px;
        border: 1px solid black;
        border-radius: 4px;
        text-transform: uppercase;
        transition: background-color 0.2s, color 0.2s;
    }

    .card-footer a:hover {
        background-color: black;
        color: white;
    }

    .link-live {
        background-color: var(--button-color);
        border-color: var(--button-color) !important;
    }

    .link-live:hover {
        background-color: #d9a52e !important;
        color: black !important;
    }

    /* ── Empty state ── */
    .no-results {
        display: none;
        padding: 2em;
        text-align: center;
        font-weight: 300;
        color: rgba(0, 0, 0, 0.45);
        font-size: 0.95em;
        letter-spacing: 0.5px;
    }

    .no-results.visible {
        display: block;
    }

    /* ── Carousel navigation ── */
    .carousel-nav {
        display: none;
        justify-content: center;
        align-items: center;
        gap: 1em;
        padding: 0.5em 1em 0;
    }

    .carousel-nav.visible {
        display: flex;
    }

    .carousel-btn {
        background: var(--button-color);
        border: 1px solid rgba(0, 0, 0, 0.15);
        border-radius: 50%;
        width: 36px;
        height: 36px;
        font-size: 20px;
        line-height: 1;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: opacity 0.2s, transform 0.2s;
        flex-shrink: 0;
    }

    .carousel-btn:disabled {
        opacity: 0.25;
        cursor: not-allowed;
        transform: none !important;
    }

    .carousel-btn:not(:disabled):hover {
        transform: scale(1.1);
    }

    .carousel-dots {
        display: flex;
        gap: 8px;
        align-items: center;
    }

    .dot {
        width: 9px;
        height: 9px;
        border-radius: 50%;
        border: none;
        background: rgba(0, 0, 0, 0.2);
        cursor: pointer;
        padding: 0;
        transition: background 0.2s, transform 0.2s;
    }

    .dot.active {
        background: var(--button-color);
        transform: scale(1.3);
    }

    /* ── Tablet / iPad: 2×2 grid (4 per page) ── */
    @media screen and (min-width: 641px) {
        #projects {
            width: 92%;
            margin: 2em auto;
        }

        .projects-title {
            padding: 1em 1.5em;
        }

        .projects-title h1 {
            font-size: 1.6em;
        }

        .projects-title::after {
            width: calc(100% - 3em);
            left: 1.5em;
        }

        .filter-bar {
            padding: 0.8em 1.5em 0;
        }

        .projects-grid {
            padding: 1.2em 1.5em;
            grid-template-columns: repeat(2, 1fr);
            gap: 1.2em;
        }

        .card-name {
            font-size: 1.05em;
        }

        .card-desc {
            font-size: 0.9em;
        }
    }

    /* ── Desktop ── */
    @media screen and (min-width: 941px) {
        #projects {
            width: 90%;
            margin: 2em auto;
        }

        .projects-title {
            padding: 1em 2em;
        }

        .projects-title h1 {
            font-size: 1.8em;
        }

        .projects-title::after {
            width: calc(100% - 4em);
            left: 2em;
        }

        .github-link img {
            width: 32px;
            height: 32px;
        }

        .filter-bar {
            padding: 1em 2em 0;
            gap: 0.6em;
        }

        .filter-btn {
            font-size: 12px;
            padding: 7px 16px;
        }

        .projects-grid {
            padding: 1.5em 2em;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5em;
        }

        .project-card {
            transition: transform 0.3s, box-shadow 0.3s;
        }

        .project-card:not([data-hidden]):hover {
            transform: scale(1.03);
            -webkit-box-shadow: 5px -5px 30px 8px rgba(0, 0, 0, 0.14);
            box-shadow: 5px -5px 30px 8px rgba(0, 0, 0, 0.14);
        }

        .card-name {
            font-size: 1.1em;
        }

        .card-desc {
            font-size: 0.95em;
        }

        .card-footer a {
            font-size: 12px;
        }

        .carousel-nav {
            padding: 0.5em 2em 0;
        }
    }

    /* ── Wide desktop ── */
    @media screen and (min-width: 1200px) {
        .projects-grid {
            padding: 2em 2.5em;
            gap: 2em;
        }

        .card-body {
            padding: 1.2em;
        }
    }
</style>

<section id="projects">
    <header class="projects-title">
        <h1>Projects</h1>
        <a class="github-link" href={githubLink} aria-label="GitHub profile">
            <img src={githubLogo} alt="GitHub">
        </a>
    </header>

    <div class="filter-bar" id="filter-bar">
        {languages.map((lang) => (
            <button
                class={'filter-btn' + (lang === 'All' ? ' active' : '')}
                data-filter={lang}
            >{lang}</button>
        ))}
    </div>

    <div class="projects-grid" id="projects-grid">
        {projects.map((obj, i) => (
            <article
                class="project-card"
                data-index={String(i)}
                data-language={obj.language}
                {...(i >= 3 ? { 'data-hidden': '' } : {})}
            >
                <header class="card-header">
                    <span class="card-language">{obj.language}</span>
                </header>
                <div class="card-body">
                    <h2 class="card-name">{obj.name}</h2>
                    <p class="card-desc">{obj.description}</p>
                    <div class="card-topics">
                        {obj.topics.map(t => (
                            <span class="topic-tag">{t}</span>
                        ))}
                    </div>
                </div>
                <footer class="card-footer">
                    {obj.live_url && (
                        <a href={obj.live_url} target="_blank" rel="noopener" class="link-live">Live Demo</a>
                    )}
                    <a href={obj.html_url} target="_blank" rel="noopener">GitHub</a>
                </footer>
            </article>
        ))}
    </div>

    <p class="no-results" id="no-results">No projects found for this language.</p>

    <div class="carousel-nav" id="carousel-nav">
        <button class="carousel-btn" id="prev-btn" aria-label="Previous page">&#8249;</button>
        <div class="carousel-dots" id="carousel-dots"></div>
        <button class="carousel-btn" id="next-btn" aria-label="Next page">&#8250;</button>
    </div>
</section>

<script>
    function initProjects() {
        var grid = document.getElementById('projects-grid');
        if (!grid) return;

        var cards = Array.from(grid.querySelectorAll('.project-card'));
        var nav = document.getElementById('carousel-nav');
        var prevBtn = document.getElementById('prev-btn');
        var nextBtn = document.getElementById('next-btn');
        var dotsContainer = document.getElementById('carousel-dots');
        var noResults = document.getElementById('no-results');
        var filterBtns = Array.from(document.querySelectorAll('.filter-btn'));

        if (!nav || !prevBtn || !nextBtn || !dotsContainer || !noResults) return;

        var currentPage = 0;
        var activeFilter = 'All';

        function itemsPerPage() {
            if (window.innerWidth < 641) return 1;
            if (window.innerWidth < 941) return 4;
            return 3;
        }

        function eligibleCards() {
            if (activeFilter === 'All') return cards;
            return cards.filter(function(card) {
                return card.getAttribute('data-language') === activeFilter;
            });
        }

        function render() {
            var eligible = eligibleCards();
            var ipp = itemsPerPage();
            var pages = Math.ceil(eligible.length / ipp);
            var start = currentPage * ipp;
            var visible = eligible.slice(start, start + ipp);

            // Hide all cards, then show only the current page of eligible ones
            cards.forEach(function(card) {
                card.setAttribute('data-hidden', '');
            });
            visible.forEach(function(card) {
                card.removeAttribute('data-hidden');
            });

            // Empty state
            if (eligible.length === 0) {
                noResults.classList.add('visible');
            } else {
                noResults.classList.remove('visible');
            }

            // Carousel nav
            prevBtn.disabled = currentPage === 0;
            nextBtn.disabled = currentPage >= pages - 1;

            dotsContainer.innerHTML = '';
            for (var i = 0; i < pages; i++) {
                var dot = document.createElement('button');
                dot.className = 'dot' + (i === currentPage ? ' active' : '');
                dot.setAttribute('aria-label', 'Page ' + (i + 1));
                (function(page) {
                    dot.addEventListener('click', function() { currentPage = page; render(); });
                })(i);
                dotsContainer.appendChild(dot);
            }

            if (pages > 1) {
                nav.classList.add('visible');
            } else {
                nav.classList.remove('visible');
            }
        }

        // Filter buttons
        filterBtns.forEach(function(btn) {
            btn.addEventListener('click', function() {
                activeFilter = btn.getAttribute('data-filter');
                currentPage = 0;
                filterBtns.forEach(function(b) { b.classList.remove('active'); });
                btn.classList.add('active');
                render();
            });
        });

        prevBtn.addEventListener('click', function() {
            if (currentPage > 0) { currentPage--; render(); }
        });

        nextBtn.addEventListener('click', function() {
            var pages = Math.ceil(eligibleCards().length / itemsPerPage());
            if (currentPage < pages - 1) { currentPage++; render(); }
        });

        // Reset on breakpoint change
        var lastIpp = itemsPerPage();
        window.addEventListener('resize', function() {
            var newIpp = itemsPerPage();
            if (newIpp !== lastIpp) {
                lastIpp = newIpp;
                currentPage = 0;
                render();
            }
        });

        render();
    }

    document.addEventListener('DOMContentLoaded', initProjects);
</script>
