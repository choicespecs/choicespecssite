---
import skills from '../data/skills.json';
---

<style>
    #skills {
        margin-top: 100px;
        width: 100%;
        height: calc(100vh - calc(100vh - 100%) - 100px);
        scroll-margin-top: 100px;
    }

    .skills-title {
        margin: 0 auto;
        display: flex;
        align-items: center;
        height: 60px;
        border-radius: 2em;
        width: 90%;
        background-color: rgba(109, 109, 109, 0.2);
    }

    .skills-title h1 {
        margin-left: 1.2em;
    }

    .skills-wrapper {
        display: flex;
        flex-direction: column;
    }

    .skills-wrapper>* {
        flex: 1;
    }

    .skill,
    .mobile-tablet-display {
        margin: 1em auto;
        display: flex;
        flex-direction: row;
        align-items: center;
        height: fit-content;
        width: 90%;
    }

    .skills-wrapper .skill:nth-child(2),
    .skills-wrapper .skill:nth-child(6) {
        flex-direction: row-reverse;
    }

    .img-wrapper {
        padding: 2em;
        width: 50%;
        height: 100%;
    }

    img {
        width: 100%;
        height: auto;
        border: 1px solid black;
        -webkit-box-shadow: -5px 5px 18px 3px rgba(0, 0, 0, 0.29);
        box-shadow: -5px 5px 18px 3px rgba(0, 0, 0, 0.29);
    }

    .content-wrapper {
        padding: 2em;
        width: 50%;
        height: 100%;
    }

    .content-wrapper>* {
        margin: 10px 0;
    }

    .skill-title {
        text-align: center;
        font-size: 20px;
        font-weight: 700;
        text-decoration: underline;
    }

    .content-wrapper p {
        font-size: 16px;
        font-weight: 400;
    }

    .skill-list {
        text-align: center;
        font-size: 18px;
        font-weight: 300;
    }

    .desktop-skill-title,
    .desktop-desc,
    .desktop-skill-list,
    .tablet-skill-title {
        display: none;
    }

    @media screen and (min-width: 641px) {
        .skill-title {
            display: none;
        }

        .tablet-skill-title {
            display: block;
            font-size: 1.2em;
            text-decoration: underline;
        }

        .skills-wrapper {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            grid-auto-flow: auto;
            grid-auto-columns: 1fr;
            grid-auto-rows: 1fr;
        }

        .skill {
            flex-direction: column;
            justify-content: space-between;
            width: 100%;
        }

        .skills-wrapper .skill:nth-child(2),
        .skills-wrapper .skill:nth-child(6) {
            flex-direction: column;
        }

        .img-wrapper {
            width: 100%;
            height: 100%;
        }

        .content-wrapper {
            padding: 0;
        }
    }

    @media screen and (min-width: 941px) {
        #skills {
            margin-top: 400px;
            margin-bottom: 400px;
        }

        .skills-wrapper {
            display: flex;
            flex-direction: column;
        }

        .skills-wrapper .desktop-skill-title:nth-child(1) {
            margin-top: 2em;
        }

        .skill {
            margin: 0 auto;
            display: grid;
            width: 80%;
            grid-auto-rows: 1fr;
            grid-template-columns: repeat(6, 1fr);
        }

        .skill-title {
            display: none;
        }

        .img-wrapper {
            width: 100%;
            grid-column: 1 / 3;
            grid-row: 1;
        }

        .img-wrapper img {
            max-height: 300px;
            max-width: 300px;
        }

        .content-wrapper {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            grid-column: 3 / 5;
            width: 100%;
            grid-row: 1;
        }

        .desktop-skill-title {
            display: block;
            margin: 0 auto;
            width: 80%;
            font-size: 1.5em;
            text-decoration: underline;
        }

        .mobile-tablet-desc,
        .skill-list,
        .tablet-skill-title {
            display: none;
        }

        .desktop-desc {
            margin: 0 auto;
            width: 80%;
            display: flex;
            flex-direction: column;
        }

        .desktop-desc>* {
            margin: 8px;
        }

        .desktop-desc p {
            line-height: 1.3;
        }

        .desktop-skill-list {
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            grid-column: 5 / -1;
            grid-row: 1;
        }

        .desktop-skill-list>* {
            margin: 20px;
        }

        .desktop-skill-list ul {
            text-align: center;
            font-size: 18px;
            font-weight: 300;
        }

        .desktop-skill-list ul li {
            margin: 12px;
        }

    }
</style>

<section id="skills">
    <header class="skills-title">
        <h1>Skills</h1>
    </header>
    <section class="skills-wrapper">
        {skills.map((obj) => (
        <h1 class="desktop-skill-title">{obj.name}</h1>
        <section class="skill">
            <div class="img-wrapper">
                <img src={obj.img_url} alt={`${obj.name}-img`}>
            </div>
            <h1 class="tablet-skill-title">{obj.name}</h1>
            <article class="content-wrapper">
                <h1 class="skill-title">{obj.name}</h1>
                <p class="mobile-tablet-desc">{obj.mobile_desc}</p>
                <article class="desktop-desc">
                    <h4>{obj.desktop_subtitle}</h4>
                    <p>{obj.desktop_desc}</p>
                    <p>{obj.desktop_exp}</p>
                </article>
                <ul class="skill-list">
                    {obj.mobile_skills.map(skill => (
                    <li>{skill}</li>
                    ))}
                </ul>
            </article>
            <div class="desktop-skill-list">
                <ul>
                    {obj.desktop_skills.map(skill => (
                    <li>{skill}</li>
                    ))}
                </ul>
            </div>
        </section>
        ))}
    </section>
</section>